{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate config — Axtazer k8s infra",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "prConcurrentLimit": 10,
  "minimumReleaseAge": "3 days",
  "pinDigests": true,
  "automerge": false,
  "kubernetes": {
    "managerFilePatterns": [
      "/argocd\\.yaml$/",
      "/bots/.+\\.yaml$/",
      "/cloudflared/.+\\.yaml$/",
      "/flo-pro/.+\\.yaml$/",
      "/monitoring/.+\\.yaml$/",
      "/pelican/.+\\.yaml$/",
      "/storageServices/.+\\.yaml$/",
      "/wings/.+\\.yaml$/",
      "/etudes/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/validate\\.yml$/"
      ],
      "matchStrings": [
        "KUBECONFORM_VERSION: \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "yannh/kubeconform",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "description": "Nextcloud stack — toujours manuel, jamais automerge (migrations BDD irréversibles)",
      "matchPackageNames": [
        "nextcloud",
        "mariadb",
        "redis"
      ],
      "matchFileNames": [
        "storageServices/nextcloud.yaml"
      ],
      "groupName": "nextcloud-stack",
      "automerge": false,
      "reviewers": [
        "Axtazer"
      ],
      "labels": [
        "nextcloud",
        "manual-review"
      ]
    },
    {
      "description": "Bloquer MariaDB major — 12.x incompatible Nextcloud + rolling release",
      "matchPackageNames": [
        "mariadb"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "description": "Pelican stack — digest/patch/minor automerge, major manuel",
      "matchPackageNames": [
        "ghcr.io/pelican-dev/panel",
        "ghcr.io/pelican-dev/wings"
      ],
      "groupName": "pelican-stack",
 
